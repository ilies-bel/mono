{
  "name": "mono-ts",
  "version": "0.3.0",
  "private": true,
  "description": "Monorepo-style git orchestration across parent + d2r2 submodules",
  "type": "module",
  "bin": {
    "mono": "./dist/mono"
  },
  "scripts": {
    "build": "bun run build:bundle && bun run build:wrapper",
    "build:bundle": "bun build src/index.ts --target=bun --outfile dist/mono.js",
    "build:wrapper": "bun scripts/emit-wrapper.ts",
    "build:static": "bun build src/index.ts --compile --minify --outfile dist/mono --target=bun",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "listr2": "^8.2.5",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
